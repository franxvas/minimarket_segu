CREATE INDEX IDX_PRODUCTO_MARCA ON PUBLIC.PRODUCTO(MARCA_ID)
CREATE INDEX IDX_PRODUCTO_STOCK ON PUBLIC.PRODUCTO(STOCK)
CREATE MEMORY TABLE PUBLIC.PROVEEDOR(ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,CORREO VARCHAR(60),DIRECCION VARCHAR(120),ESTADO BOOLEAN NOT NULL,FECHAREGISTRO TIMESTAMP,NOMBRE VARCHAR(80) NOT NULL,RUC VARCHAR(11) NOT NULL,TELEFONO VARCHAR(15),CONSTRAINT UK_PROVEEDOR_RUC UNIQUE(RUC),CONSTRAINT UK_PROVEEDOR_CORREO UNIQUE(CORREO))
ALTER TABLE PUBLIC.PROVEEDOR ALTER COLUMN ID RESTART WITH 81
CREATE INDEX IDX_PROVEEDOR_NOMBRE ON PUBLIC.PROVEEDOR(NOMBRE)
CREATE MEMORY TABLE PUBLIC.ROL(ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,DESCRIPCION VARCHAR(150),ESTADO BOOLEAN NOT NULL,FECHAREGISTRO TIMESTAMP,NOMBRE VARCHAR(40) NOT NULL,USUARIOREGISTRO VARCHAR(30),CONSTRAINT UK_ROL_NOMBRE UNIQUE(NOMBRE))
ALTER TABLE PUBLIC.ROL ALTER COLUMN ID RESTART WITH 7
