CREATE MEMORY TABLE PUBLIC.USUARIOSISTEMA(ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,ESTADO BOOLEAN NOT NULL,FECHAREGISTRO TIMESTAMP,PASSWORD VARCHAR(100) NOT NULL,ULTIMOACCESO TIMESTAMP,USERNAME VARCHAR(30) NOT NULL,EMPLEADO_ID BIGINT NOT NULL,CONSTRAINT UK_USUARIO_USERNAME UNIQUE(USERNAME),CONSTRAINT FKBOCB3FPX2N9I5DJ4DDF4E9R78 FOREIGN KEY(EMPLEADO_ID) REFERENCES PUBLIC.EMPLEADO(ID))
ALTER TABLE PUBLIC.USUARIOSISTEMA ALTER COLUMN ID RESTART WITH 13
