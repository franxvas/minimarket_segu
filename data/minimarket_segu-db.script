CREATE MEMORY TABLE PUBLIC.CARGO(ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,DESCRIPCION VARCHAR(150),ESTADO BOOLEAN NOT NULL,NOMBRE VARCHAR(50) NOT NULL,SUELDOBASE NUMERIC(12,2) NOT NULL,USUARIOREGISTRO VARCHAR(30),CONSTRAINT UK_CARGO_NOMBRE UNIQUE(NOMBRE))
ALTER TABLE PUBLIC.CARGO ALTER COLUMN ID RESTART WITH 9
CREATE MEMORY TABLE PUBLIC.CATEGORIAPRODUCTO(ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,DESCRIPCION VARCHAR(150),ESTADO BOOLEAN NOT NULL,FECHAREGISTRO TIMESTAMP,NOMBRE VARCHAR(40) NOT NULL,USUARIOREGISTRO VARCHAR(30),CONSTRAINT UK_CATEGORIA_NOMBRE UNIQUE(NOMBRE))
ALTER TABLE PUBLIC.CATEGORIAPRODUCTO ALTER COLUMN ID RESTART WITH 29
CREATE MEMORY TABLE PUBLIC.CLIENTE(ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,CORREO VARCHAR(60),DIRECCION VARCHAR(120),DNI VARCHAR(8) NOT NULL,FECHAREGISTRO TIMESTAMP,NOMBRE VARCHAR(80) NOT NULL,RAZONSOCIAL VARCHAR(100),RUC VARCHAR(11),TELEFONO VARCHAR(15),TIPOCLIENTE VARCHAR(12) NOT NULL,CONSTRAINT UK_CLIENTE_DNI UNIQUE(DNI),CONSTRAINT UK_CLIENTE_RUC UNIQUE(RUC),CONSTRAINT UK_CLIENTE_CORREO UNIQUE(CORREO))
ALTER TABLE PUBLIC.CLIENTE ALTER COLUMN ID RESTART WITH 3001
CREATE INDEX IDX_CLIENTE_NOMBRE ON PUBLIC.CLIENTE(NOMBRE)
CREATE MEMORY TABLE PUBLIC.COMPRA(ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,ESTADO BOOLEAN NOT NULL,FECHA TIMESTAMP,NUMEROCOMPROBANTE VARCHAR(20) NOT NULL,PROCESADA BOOLEAN NOT NULL,TIPOCOMPROBANTE VARCHAR(20) NOT NULL,USUARIOREGISTRO VARCHAR(30),PROVEEDOR_ID BIGINT NOT NULL,CONSTRAINT UK_COMPRA_COMPROBANTE UNIQUE(TIPOCOMPROBANTE,NUMEROCOMPROBANTE))
ALTER TABLE PUBLIC.COMPRA ALTER COLUMN ID RESTART WITH 901
CREATE INDEX IDX_COMPRA_FECHA ON PUBLIC.COMPRA(FECHA)
CREATE INDEX IDX_COMPRA_PROVEEDOR ON PUBLIC.COMPRA(PROVEEDOR_ID)
