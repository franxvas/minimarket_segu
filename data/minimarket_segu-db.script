CREATE MEMORY TABLE PUBLIC.DETALLE_VENTA(VENTA_ID BIGINT NOT NULL,CANTIDAD INTEGER NOT NULL,PRECIO NUMERIC(12,2) NOT NULL,PRODUCTO_ID BIGINT NOT NULL,LINEA INTEGER NOT NULL,PRIMARY KEY(VENTA_ID,LINEA))
CREATE MEMORY TABLE PUBLIC.EMPLEADO(ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,CORREO VARCHAR(60),DIRECCION VARCHAR(120),DNI VARCHAR(8) NOT NULL,FECHAINGRESO TIMESTAMP,NOMBRE VARCHAR(80) NOT NULL,TELEFONO VARCHAR(15),CARGO_ID BIGINT NOT NULL,CONSTRAINT UK_EMPLEADO_DNI UNIQUE(DNI),CONSTRAINT UK_EMPLEADO_CORREO UNIQUE(CORREO),CONSTRAINT FKMF5BXQM9QCYMNE9IHKBH6BF4S FOREIGN KEY(CARGO_ID) REFERENCES PUBLIC.CARGO(ID))
ALTER TABLE PUBLIC.EMPLEADO ALTER COLUMN ID RESTART WITH 25
CREATE INDEX IDX_EMPLEADO_NOMBRE ON PUBLIC.EMPLEADO(NOMBRE)
CREATE MEMORY TABLE PUBLIC.MARCA(ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,DESCRIPCION VARCHAR(150),ESTADO BOOLEAN NOT NULL,FECHAREGISTRO TIMESTAMP,NOMBRE VARCHAR(40) NOT NULL,PAISORIGEN VARCHAR(40),CONSTRAINT UK_MARCA_NOMBRE UNIQUE(NOMBRE))
ALTER TABLE PUBLIC.MARCA ALTER COLUMN ID RESTART WITH 121
CREATE MEMORY TABLE PUBLIC.METODOPAGO(ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,DESCRIPCION VARCHAR(150),ESTADO BOOLEAN NOT NULL,FECHAREGISTRO TIMESTAMP,NOMBRE VARCHAR(40) NOT NULL,USUARIOREGISTRO VARCHAR(30),CONSTRAINT UK_METODO_PAGO_NOMBRE UNIQUE(NOMBRE))
ALTER TABLE PUBLIC.METODOPAGO ALTER COLUMN ID RESTART WITH 6
CREATE MEMORY TABLE PUBLIC.PRODUCTO(ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,DESCRIPCION VARCHAR(200),NOMBRE VARCHAR(50) NOT NULL,PRECIOCOMPRA NUMERIC(12,2) NOT NULL,PRECIOMAYORISTA NUMERIC(12,2) NOT NULL,PRECIOVENTA NUMERIC(12,2) NOT NULL,STOCK INTEGER NOT NULL,STOCKMINIMO INTEGER NOT NULL,CATEGORIA_ID BIGINT NOT NULL,MARCA_ID BIGINT NOT NULL,CHECK(PUBLIC.PRODUCTO.STOCK>=0),CHECK(PUBLIC.PRODUCTO.STOCKMINIMO>=0),CONSTRAINT UK_PRODUCTO_NOMBRE UNIQUE(NOMBRE),CONSTRAINT FK67QEWBQ9KQCNQ43LHXTRBX2S FOREIGN KEY(CATEGORIA_ID) REFERENCES PUBLIC.CATEGORIAPRODUCTO(ID),CONSTRAINT FKRWUDXUMJDD4FQPCHH58D5DDA FOREIGN KEY(MARCA_ID) REFERENCES PUBLIC.MARCA(ID))
ALTER TABLE PUBLIC.PRODUCTO ALTER COLUMN ID RESTART WITH 1801
